<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_aivio_billing" model="ir.ui.view">
        <field name="name">account.move.form.aivio.billing</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="aivio_unit_id"/>
                <field name="aivio_resident_profile_id"/>
                <field name="aivio_contract_id"/>
                <field name="aivio_ticket_id"/>
            </xpath>
        </field>
    </record>
</odoo>
