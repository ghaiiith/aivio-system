<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_aivio_mobile_core" model="ir.ui.view">
        <field name="name">res.users.form.aivio.mobile.core</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="AIVIO Mobile">
                    <group>
                        <field name="aivio_app_role" readonly="1"/>
                    </group>
                    <field name="aivio_api_token_ids" readonly="1"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
