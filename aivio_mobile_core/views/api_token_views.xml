<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_aivio_api_token_list" model="ir.ui.view">
        <field name="name">aivio.api.token.list</field>
        <field name="model">aivio.api.token</field>
        <field name="arch" type="xml">
            <list string="API Tokens" create="0">
                <field name="name"/>
                <field name="user_id"/>
                <field name="app_role"/>
                <field name="active"/>
                <field name="expires_at"/>
                <field name="last_used_at"/>
                <field name="ip_address"/>
            </list>
        </field>
    </record>
    <record id="view_aivio_api_token_form" model="ir.ui.view">
        <field name="name">aivio.api.token.form</field>
        <field name="model">aivio.api.token</field>
        <field name="arch" type="xml">
            <form string="API Token" create="0">
                <header>
                    <button name="revoke" type="object" string="Revoke" class="btn-secondary" invisible="not active"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="user_id"/>
                        <field name="app_role"/>
                        <field name="active"/>
                        <field name="expires_at"/>
                        <field name="last_used_at"/>
                    </group>
                    <group string="Request Context">
                        <field name="ip_address"/>
                        <field name="user_agent"/>
                        <field name="device_token"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_aivio_api_tokens" model="ir.actions.act_window">
        <field name="name">API Tokens</field>
        <field name="res_model">aivio.api.token</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_aivio_api_tokens" name="API Tokens" parent="aivio_mobile_core.menu_aivio_api" action="action_aivio_api_tokens" sequence="10"/>
</odoo>
