<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_aivio_api_audit_log_list" model="ir.ui.view">
        <field name="name">aivio.api.audit.log.list</field>
        <field name="model">aivio.api.audit.log</field>
        <field name="arch" type="xml">
            <list string="API Audit Logs" create="0" edit="0">
                <field name="create_date"/>
                <field name="user_id"/>
                <field name="method"/>
                <field name="endpoint"/>
                <field name="status"/>
                <field name="response_message"/>
                <field name="ip_address"/>
            </list>
        </field>
    </record>
    <record id="view_aivio_api_audit_log_form" model="ir.ui.view">
        <field name="name">aivio.api.audit.log.form</field>
        <field name="model">aivio.api.audit.log</field>
        <field name="arch" type="xml">
            <form string="API Audit Log" create="0" edit="0">
                <sheet>
                    <group>
                        <field name="create_date"/>
                        <field name="user_id"/>
                        <field name="method"/>
                        <field name="endpoint"/>
                        <field name="status"/>
                        <field name="ip_address"/>
                        <field name="response_message"/>
                    </group>
                    <group>
                        <field name="payload" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_aivio_api_audit_logs" model="ir.actions.act_window">
        <field name="name">API Audit Logs</field>
        <field name="res_model">aivio.api.audit.log</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_aivio_api_audit_logs" name="API Audit Logs" parent="aivio_mobile_core.menu_aivio_api" action="action_aivio_api_audit_logs" sequence="20"/>
</odoo>
