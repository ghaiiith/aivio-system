<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_aivio" model="ir.module.category">
        <field name="name">AIVIO</field>
        <field name="description">AIVIO residential community management.</field>
        <field name="sequence">25</field>
    </record>

    <record id="res_groups_privilege_aivio_mobile" model="res.groups.privilege">
        <field name="name">Mobile Apps</field>
        <field name="category_id" ref="module_category_aivio"/>
        <field name="sequence">25</field>
        <field name="placeholder">No Access</field>
    </record>

    <record id="group_aivio_manager" model="res.groups">
        <field name="name">AIVIO / Manager</field>
        <field name="privilege_id" ref="res_groups_privilege_aivio_mobile"/>
        <field name="sequence">10</field>
    </record>

    <record id="group_aivio_resident_user" model="res.groups">
        <field name="name">AIVIO / Resident User</field>
        <field name="privilege_id" ref="res_groups_privilege_aivio_mobile"/>
        <field name="sequence">20</field>
        <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <record id="group_aivio_security_user" model="res.groups">
        <field name="name">AIVIO / Security User</field>
        <field name="privilege_id" ref="res_groups_privilege_aivio_mobile"/>
        <field name="sequence">30</field>
        <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <record id="group_aivio_maintenance_user" model="res.groups">
        <field name="name">AIVIO / Maintenance Technician</field>
        <field name="privilege_id" ref="res_groups_privilege_aivio_mobile"/>
        <field name="sequence">40</field>
        <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <record id="group_aivio_maintenance_supervisor" model="res.groups">
        <field name="name">AIVIO / Maintenance Supervisor</field>
        <field name="privilege_id" ref="res_groups_privilege_aivio_mobile"/>
        <field name="sequence">50</field>
        <field name="implied_ids" eval="[(4, ref('base.group_portal')), (4, ref('aivio_mobile_core.group_aivio_maintenance_user'))]"/>
    </record>
</odoo>
