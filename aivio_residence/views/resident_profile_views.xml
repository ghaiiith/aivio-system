<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_aivio_resident_profile_list" model="ir.ui.view">
        <field name="name">aivio.resident.profile.list</field>
        <field name="model">aivio.resident.profile</field>
        <field name="arch" type="xml">
            <list string="Residents">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="resident_type"/>
                <field name="primary_unit_id"/>
                <field name="state"/>
                <field name="mobile"/>
            </list>
        </field>
    </record>
    <record id="view_aivio_resident_profile_form" model="ir.ui.view">
        <field name="name">aivio.resident.profile.form</field>
        <field name="model">aivio.resident.profile</field>
        <field name="arch" type="xml">
            <form string="Resident Profile">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_family_members" type="object" class="oe_stat_button" icon="fa-users">
                            <field name="family_member_count" widget="statinfo" string="Family"/>
                        </button>
                        <button name="action_open_vehicles" type="object" class="oe_stat_button" icon="fa-car">
                            <field name="vehicle_count" widget="statinfo" string="Vehicles"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="user_id"/>
                            <field name="resident_type"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="primary_unit_id"/>
                            <field name="unit_ids" widget="many2many_tags"/>
                            <field name="phone"/>
                            <field name="mobile"/>
                            <field name="email"/>
                        </group>
                    </group>
                    <group string="Emergency Contact">
                        <field name="emergency_contact_name"/>
                        <field name="emergency_contact_phone"/>
                    </group>
                    <notebook>
                        <page string="Family Members">
                            <field name="family_member_ids"/>
                        </page>
                        <page string="Vehicles">
                            <field name="vehicle_ids"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_aivio_resident_profiles" model="ir.actions.act_window">
        <field name="name">Residents</field>
        <field name="res_model">aivio.resident.profile</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
