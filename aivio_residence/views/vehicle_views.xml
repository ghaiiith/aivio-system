<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_aivio_resident_vehicle_list" model="ir.ui.view">
        <field name="name">aivio.resident.vehicle.list</field>
        <field name="model">aivio.resident.vehicle</field>
        <field name="arch" type="xml">
            <list string="Vehicles">
                <field name="plate_number"/>
                <field name="resident_id"/>
                <field name="unit_id"/>
                <field name="brand"/>
                <field name="model"/>
                <field name="color"/>
                <field name="authorized"/>
            </list>
        </field>
    </record>
    <record id="view_aivio_resident_vehicle_form" model="ir.ui.view">
        <field name="name">aivio.resident.vehicle.form</field>
        <field name="model">aivio.resident.vehicle</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <sheet>
                    <group>
                        <field name="resident_id"/>
                        <field name="unit_id"/>
                        <field name="plate_number"/>
                        <field name="vehicle_type"/>
                        <field name="brand"/>
                        <field name="model"/>
                        <field name="color"/>
                        <field name="authorized"/>
                        <field name="active"/>
                    </group>
                    <field name="notes"/>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_aivio_resident_vehicles" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">aivio.resident.vehicle</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
