<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_aivio_family_member_list" model="ir.ui.view">
        <field name="name">aivio.family.member.list</field>
        <field name="model">aivio.family.member</field>
        <field name="arch" type="xml">
            <list string="Family Members">
                <field name="name"/>
                <field name="resident_id"/>
                <field name="relation"/>
                <field name="phone"/>
                <field name="identification_no"/>
            </list>
        </field>
    </record>
    <record id="view_aivio_family_member_form" model="ir.ui.view">
        <field name="name">aivio.family.member.form</field>
        <field name="model">aivio.family.member</field>
        <field name="arch" type="xml">
            <form string="Family Member">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="resident_id"/>
                        <field name="relation"/>
                        <field name="phone"/>
                        <field name="identification_no"/>
                        <field name="birth_date"/>
                        <field name="active"/>
                    </group>
                    <field name="notes"/>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_aivio_family_members" model="ir.actions.act_window">
        <field name="name">Family Members</field>
        <field name="res_model">aivio.family.member</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
