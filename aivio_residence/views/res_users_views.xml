<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_aivio_residence" model="ir.ui.view">
        <field name="name">res.users.form.aivio.residence</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="AIVIO Residence">
                    <group>
                        <field name="aivio_unit_ids" widget="many2many_tags"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
