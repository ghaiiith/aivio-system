<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_aivio_resident_profile_own" model="ir.rule">
        <field name="name">AIVIO resident can access own profile</field>
        <field name="model_id" ref="model_aivio_resident_profile"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('aivio_mobile_core.group_aivio_resident_user'))]"/>
    </record>
    <record id="rule_aivio_family_member_own" model="ir.rule">
        <field name="name">AIVIO resident can access own family members</field>
        <field name="model_id" ref="model_aivio_family_member"/>
        <field name="domain_force">[('resident_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('aivio_mobile_core.group_aivio_resident_user'))]"/>
    </record>
    <record id="rule_aivio_vehicle_own" model="ir.rule">
        <field name="name">AIVIO resident can access own vehicles</field>
        <field name="model_id" ref="model_aivio_resident_vehicle"/>
        <field name="domain_force">[('resident_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('aivio_mobile_core.group_aivio_resident_user'))]"/>
    </record>
</odoo>
