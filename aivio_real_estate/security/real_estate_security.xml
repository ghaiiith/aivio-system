<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_aivio_real_estate" model="ir.module.category">
        <field name="name">AIVIO Real Estate</field>
        <field name="description">Real estate management access rights.</field>
        <field name="sequence">30</field>
    </record>

    <record id="res_groups_privilege_aivio_real_estate" model="res.groups.privilege">
        <field name="name">Real Estate</field>
        <field name="category_id" ref="module_category_aivio_real_estate"/>
        <field name="sequence">30</field>
        <field name="placeholder">No Access</field>
    </record>

    <record id="group_real_estate_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="res_groups_privilege_aivio_real_estate"/>
        <field name="sequence">10</field>
    </record>

    <record id="group_real_estate_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="res_groups_privilege_aivio_real_estate"/>
        <field name="sequence">20</field>
        <field name="implied_ids" eval="[(4, ref('group_real_estate_user'))]"/>
    </record>

    <record id="rule_real_estate_region_company" model="ir.rule">
        <field name="name">Real Estate Regions: company</field>
        <field name="model_id" ref="model_aivio_real_estate_region"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_real_estate_user'))]"/>
    </record>

    <record id="rule_real_estate_project_company" model="ir.rule">
        <field name="name">Real Estate Projects: company</field>
        <field name="model_id" ref="model_aivio_real_estate_project"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_real_estate_user'))]"/>
    </record>

    <record id="rule_real_estate_floor_company" model="ir.rule">
        <field name="name">Real Estate Floors: company</field>
        <field name="model_id" ref="model_aivio_real_estate_floor"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_real_estate_user'))]"/>
    </record>

    <record id="rule_real_estate_unit_company" model="ir.rule">
        <field name="name">Real Estate Units: company</field>
        <field name="model_id" ref="model_aivio_real_estate_unit"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_real_estate_user'))]"/>
    </record>

    <record id="rule_real_estate_reservation_company" model="ir.rule">
        <field name="name">Real Estate Reservations: company</field>
        <field name="model_id" ref="model_aivio_real_estate_reservation"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_real_estate_user'))]"/>
    </record>

    <record id="rule_real_estate_contract_company" model="ir.rule">
        <field name="name">Real Estate Contracts: company</field>
        <field name="model_id" ref="model_aivio_real_estate_contract"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_real_estate_user'))]"/>
    </record>

    <record id="rule_real_estate_installment_company" model="ir.rule">
        <field name="name">Real Estate Installments: company</field>
        <field name="model_id" ref="model_aivio_real_estate_installment"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_real_estate_user'))]"/>
    </record>

    <record id="rule_real_estate_unit_image_company" model="ir.rule">
        <field name="name">Real Estate Unit Images: company</field>
        <field name="model_id" ref="model_aivio_real_estate_unit_image"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_real_estate_user'))]"/>
    </record>
</odoo>
