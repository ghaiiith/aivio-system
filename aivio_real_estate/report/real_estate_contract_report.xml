<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_aivio_real_estate_contract" model="ir.actions.report">
        <field name="name">Real Estate Contract</field>
        <field name="model">aivio.real.estate.contract</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">aivio_real_estate.report_real_estate_contract_document</field>
        <field name="report_file">aivio_real_estate.report_real_estate_contract_document</field>
        <field name="binding_model_id" ref="model_aivio_real_estate_contract"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_real_estate_contract_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Real Estate Contract</h2>
                        <div class="row mt16 mb16">
                            <div class="col-6">
                                <strong>Contract:</strong> <span t-field="doc.name"/><br/>
                                <strong>Type:</strong> <span t-field="doc.contract_type"/><br/>
                                <strong>Status:</strong> <span t-field="doc.state"/><br/>
                                <strong>Start Date:</strong> <span t-field="doc.date_start"/><br/>
                                <t t-if="doc.date_end"><strong>End Date:</strong> <span t-field="doc.date_end"/><br/></t>
                            </div>
                            <div class="col-6">
                                <strong>Customer:</strong> <span t-field="doc.partner_id"/><br/>
                                <strong>Project:</strong> <span t-field="doc.project_id"/><br/>
                                <strong>Unit:</strong> <span t-field="doc.unit_id"/><br/>
                                <strong>Value:</strong> <span t-field="doc.contract_value" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/><br/>
                                <strong>Deposit:</strong> <span t-field="doc.deposit_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </div>
                        </div>
                        <h3>Installment Schedule</h3>
                        <table class="table table-sm o_main_table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Description</th>
                                    <th>Due Date</th>
                                    <th class="text-end">Amount</th>
                                    <th>Invoice</th>
                                    <th>Payment</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.installment_ids" t-as="line">
                                    <td><span t-field="line.sequence"/></td>
                                    <td><span t-field="line.name"/></td>
                                    <td><span t-field="line.due_date"/></td>
                                    <td class="text-end"><span t-field="line.amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td><span t-field="line.invoice_state"/></td>
                                    <td><span t-field="line.payment_state"/></td>
                                </tr>
                            </tbody>
                        </table>
                        <div class="row mt32">
                            <div class="col-6 text-center">
                                <p>Customer Signature</p>
                                <br/><br/>
                                <p>________________________</p>
                            </div>
                            <div class="col-6 text-center">
                                <p>Company Signature</p>
                                <br/><br/>
                                <p>________________________</p>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
