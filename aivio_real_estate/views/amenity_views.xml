<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_aivio_real_estate_amenity_list" model="ir.ui.view">
        <field name="name">aivio.real.estate.amenity.list</field>
        <field name="model">aivio.real.estate.amenity</field>
        <field name="arch" type="xml">
            <list string="Amenities" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="color"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_aivio_real_estate_amenity_form" model="ir.ui.view">
        <field name="name">aivio.real.estate.amenity.form</field>
        <field name="model">aivio.real.estate.amenity</field>
        <field name="arch" type="xml">
            <form string="Amenity">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="color"/>
                        <field name="active"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_aivio_real_estate_amenities" model="ir.actions.act_window">
        <field name="name">Amenities</field>
        <field name="res_model">aivio.real.estate.amenity</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
