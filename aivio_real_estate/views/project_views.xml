<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_aivio_real_estate_project_list" model="ir.ui.view">
        <field name="name">aivio.real.estate.project.list</field>
        <field name="model">aivio.real.estate.project</field>
        <field name="arch" type="xml">
            <list string="Projects" decoration-muted="state == 'closed'" decoration-success="state == 'available'" decoration-warning="state == 'planning'">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="region_id"/>
                <field name="unit_count"/>
                <field name="available_unit_count"/>
                <field name="occupancy_rate" widget="percentage"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'planning'" decoration-success="state == 'available'" decoration-muted="state == 'closed'"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_aivio_real_estate_project_kanban" model="ir.ui.view">
        <field name="name">aivio.real.estate.project.kanban</field>
        <field name="model">aivio.real.estate.project</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state">
                <field name="name"/>
                <field name="code"/>
                <field name="region_id"/>
                <field name="state"/>
                <field name="unit_count"/>
                <field name="available_unit_count"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_title"><strong><field name="name"/></strong></div>
                            <div class="text-muted"><field name="code"/> · <field name="region_id"/></div>
                            <div class="mt8">Units: <field name="unit_count"/> | Available: <field name="available_unit_count"/></div>
                            <field name="state" widget="badge"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_aivio_real_estate_project_form" model="ir.ui.view">
        <field name="name">aivio.real.estate.project.form</field>
        <field name="model">aivio.real.estate.project</field>
        <field name="arch" type="xml">
            <form string="Project">
                <header>
                    <button name="action_set_planning" type="object" string="Set Planning" class="btn-secondary" invisible="state != 'draft'"/>
                    <button name="action_set_available" type="object" string="Set Available" class="oe_highlight" invisible="state not in ('draft', 'planning')"/>
                    <button name="action_close" type="object" string="Close" class="btn-secondary" invisible="state == 'closed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,planning,available,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_floors" type="object" class="oe_stat_button" icon="fa-bars">
                            <field name="floor_count" widget="statinfo" string="Floors"/>
                        </button>
                        <button name="action_open_units" type="object" class="oe_stat_button" icon="fa-home">
                            <field name="unit_count" widget="statinfo" string="Units"/>
                        </button>
                    </div>
                    <field name="image_1920" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Project / Building Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" readonly="1"/>
                            <field name="region_id"/>
                            <field name="address"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="latitude"/>
                            <field name="longitude"/>
                            <field name="unit_count" readonly="1"/>
                            <field name="available_unit_count" readonly="1"/>
                            <field name="reserved_unit_count" readonly="1"/>
                            <field name="sold_unit_count" readonly="1"/>
                            <field name="rented_unit_count" readonly="1"/>
                            <field name="occupancy_rate" widget="percentage" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Floors">
                            <field name="floor_ids" context="{'default_project_id': id}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="floor_number"/>
                                    <field name="area"/>
                                    <field name="unit_count" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Units">
                            <field name="unit_ids" context="{'default_project_id': id}">
                                <list>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="floor_id"/>
                                    <field name="unit_type_id"/>
                                    <field name="sale_price"/>
                                    <field name="rent_price"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_aivio_real_estate_project_search" model="ir.ui.view">
        <field name="name">aivio.real.estate.project.search</field>
        <field name="model">aivio.real.estate.project</field>
        <field name="arch" type="xml">
            <search string="Projects">
                <field name="name"/>
                <field name="code"/>
                <field name="region_id"/>
                <filter string="Available" name="available" domain="[('state', '=', 'available')]"/>
                <filter string="Planning" name="planning" domain="[('state', '=', 'planning')]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Region" name="group_region" context="{'group_by': 'region_id'}"/>
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </search>
        </field>
    </record>

    <record id="action_aivio_real_estate_projects" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">aivio.real.estate.project</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_aivio_real_estate_project_search"/>
    </record>
</odoo>
