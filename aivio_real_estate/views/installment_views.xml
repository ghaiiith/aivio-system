<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_aivio_real_estate_installment_list" model="ir.ui.view">
        <field name="name">aivio.real.estate.installment.list</field>
        <field name="model">aivio.real.estate.installment</field>
        <field name="arch" type="xml">
            <list string="Installments" decoration-danger="payment_state in ('not_paid', 'partial')" decoration-success="payment_state == 'paid'">
                <field name="sequence"/>
                <field name="name"/>
                <field name="contract_id"/>
                <field name="partner_id"/>
                <field name="unit_id"/>
                <field name="due_date"/>
                <field name="amount"/>
                <field name="invoice_id"/>
                <field name="invoice_state" widget="badge"/>
                <field name="payment_state" widget="badge"/>
                <field name="amount_residual"/>
                <button name="action_create_invoice" type="object" string="Create Invoice" class="btn-primary" invisible="invoice_id"/>
                <button name="action_open_invoice" type="object" string="Open Invoice" invisible="not invoice_id"/>
            </list>
        </field>
    </record>

    <record id="view_aivio_real_estate_installment_form" model="ir.ui.view">
        <field name="name">aivio.real.estate.installment.form</field>
        <field name="model">aivio.real.estate.installment</field>
        <field name="arch" type="xml">
            <form string="Installment">
                <header>
                    <button name="action_create_invoice" type="object" string="Create Invoice" class="oe_highlight" invisible="invoice_id"/>
                    <button name="action_open_invoice" type="object" string="Open Invoice" invisible="not invoice_id"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="contract_id"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="unit_id" readonly="1"/>
                            <field name="project_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="due_date"/>
                            <field name="amount"/>
                            <field name="amount_residual" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="invoice_id" readonly="1"/>
                        <field name="invoice_state" readonly="1"/>
                        <field name="payment_state" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_aivio_real_estate_installment_search" model="ir.ui.view">
        <field name="name">aivio.real.estate.installment.search</field>
        <field name="model">aivio.real.estate.installment</field>
        <field name="arch" type="xml">
            <search string="Installments">
                <field name="name"/>
                <field name="contract_id"/>
                <field name="partner_id"/>
                <field name="unit_id"/>
                <filter string="Not Invoiced" name="not_invoiced" domain="[('invoice_id', '=', False)]"/>
                <filter string="Invoiced" name="invoiced" domain="[('invoice_id', '!=', False)]"/>
                <filter string="Unpaid" name="unpaid" domain="[('payment_state', 'in', ('not_paid', 'partial'))]"/>
                <filter string="Paid" name="paid" domain="[('payment_state', '=', 'paid')]"/>
                <separator/>
                
                    <filter string="Due Date" name="group_due_date" context="{'group_by': 'due_date'}"/>
                    <filter string="Customer" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Contract" name="group_contract" context="{'group_by': 'contract_id'}"/>
                </search>
        </field>
    </record>

    <record id="action_aivio_real_estate_installments" model="ir.actions.act_window">
        <field name="name">Installments</field>
        <field name="res_model">aivio.real.estate.installment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_aivio_real_estate_installment_search"/>
    </record>
</odoo>
