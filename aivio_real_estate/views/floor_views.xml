<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_aivio_real_estate_floor_list" model="ir.ui.view">
        <field name="name">aivio.real.estate.floor.list</field>
        <field name="model">aivio.real.estate.floor</field>
        <field name="arch" type="xml">
            <list string="Floors">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="floor_number"/>
                <field name="area"/>
                <field name="unit_count"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_aivio_real_estate_floor_form" model="ir.ui.view">
        <field name="name">aivio.real.estate.floor.form</field>
        <field name="model">aivio.real.estate.floor</field>
        <field name="arch" type="xml">
            <form string="Floor">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_units" type="object" class="oe_stat_button" icon="fa-home">
                            <field name="unit_count" widget="statinfo" string="Units"/>
                        </button>
                    </div>
                    <field name="image_1920" widget="image" class="oe_avatar"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="project_id"/>
                            <field name="sequence"/>
                            <field name="floor_number"/>
                            <field name="area"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company" readonly="1"/>
                            <field name="unit_count" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Units">
                            <field name="unit_ids" context="{'default_project_id': project_id, 'default_floor_id': id}">
                                <list>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="unit_type_id"/>
                                    <field name="area"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_aivio_real_estate_floors" model="ir.actions.act_window">
        <field name="name">Floors</field>
        <field name="res_model">aivio.real.estate.floor</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
