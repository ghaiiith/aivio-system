<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="seq_real_estate_project" model="ir.sequence">
        <field name="name">Real Estate Project</field>
        <field name="code">aivio.real.estate.project</field>
        <field name="prefix">PRJ/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
    <record id="seq_real_estate_unit" model="ir.sequence">
        <field name="name">Real Estate Unit</field>
        <field name="code">aivio.real.estate.unit</field>
        <field name="prefix">UNIT/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
    <record id="seq_real_estate_reservation" model="ir.sequence">
        <field name="name">Real Estate Reservation</field>
        <field name="code">aivio.real.estate.reservation</field>
        <field name="prefix">RSV/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
    <record id="seq_real_estate_contract" model="ir.sequence">
        <field name="name">Real Estate Contract</field>
        <field name="code">aivio.real.estate.contract</field>
        <field name="prefix">CNT/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
