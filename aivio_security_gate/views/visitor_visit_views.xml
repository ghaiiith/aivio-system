<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_aivio_visitor_visit_list" model="ir.ui.view"><field name="name">aivio.visitor.visit.list</field><field name="model">aivio.visitor.visit</field><field name="arch" type="xml"><list><field name="visit_datetime"/><field name="name"/><field name="visitor_name"/><field name="visitor_phone"/><field name="resident_id"/><field name="unit_id"/><field name="gate_id"/><field name="valid_to"/><field name="status"/></list></field></record>
    <record id="view_aivio_visitor_visit_form" model="ir.ui.view"><field name="name">aivio.visitor.visit.form</field><field name="model">aivio.visitor.visit</field><field name="arch" type="xml"><form><header><button name="action_check_in" type="object" string="Check In" invisible="status not in ['pending','approved']"/><button name="action_check_out" type="object" string="Check Out" invisible="status != 'arrived'"/><button name="action_cancel" type="object" string="Cancel" invisible="status in ['cancelled','checked_out']"/><field name="status" widget="statusbar"/></header><sheet><group><group><field name="name"/><field name="visitor_name"/><field name="visitor_phone"/><field name="visitor_id_number"/><field name="visitor_count"/><field name="visit_type"/><field name="reason"/></group><group><field name="resident_id"/><field name="unit_id"/><field name="building_id"/><field name="gate_id"/><field name="valid_from"/><field name="valid_to"/><field name="visit_datetime"/></group></group><group string="Vehicle"><field name="has_car"/><field name="car_plate" invisible="not has_car"/></group><group string="QR / Confirmation"><field name="qr_token" readonly="1"/><field name="checked_in_at"/><field name="checked_out_at"/><field name="confirmed_by_id"/><field name="confirmed_gate_id"/></group><notebook><page string="Access Logs"><field name="access_log_ids" readonly="1"/></page><page string="Notes"><field name="note" nolabel="1"/></page></notebook></sheet><chatter/></form></field></record>
    <record id="action_aivio_visitor_visits" model="ir.actions.act_window"><field name="name">Visitors</field><field name="res_model">aivio.visitor.visit</field><field name="view_mode">list,form</field></record>
</odoo>
