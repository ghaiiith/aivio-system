    <record id="view_aivio_guard_shift_list" model="ir.ui.view"><field name="name">aivio.guard.shift.list</field><field name="model">aivio.guard.shift</field><field name="arch" type="xml"><list><field name="date"/><field name="name"/><field name="gate_id"/><field name="user_id"/><field name="start_datetime"/><field name="end_datetime"/><field name="state"/></list></field></record>
