<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_aivio_ticket_resident_own" model="ir.rule">
        <field name="name">AIVIO resident can access own tickets</field>
        <field name="model_id" ref="model_aivio_maintenance_ticket"/>
        <field name="domain_force">[('resident_user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('aivio_mobile_core.group_aivio_resident_user'))]"/>
    </record>
    <record id="rule_aivio_ticket_maintenance_team" model="ir.rule">
        <field name="name">AIVIO technician can access assigned/team tickets</field>
        <field name="model_id" ref="model_aivio_maintenance_ticket"/>
        <field name="domain_force">['|', ('assigned_user_id', '=', user.id), ('team_id', 'in', user.aivio_maintenance_team_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('aivio_mobile_core.group_aivio_maintenance_user'))]"/>
    </record>
    <record id="rule_aivio_ticket_supervisor_team" model="ir.rule">
        <field name="name">AIVIO supervisor can access team tickets</field>
        <field name="model_id" ref="model_aivio_maintenance_ticket"/>
        <field name="domain_force">[('team_id', 'in', user.aivio_maintenance_team_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('aivio_mobile_core.group_aivio_maintenance_supervisor'))]"/>
    </record>
</odoo>
